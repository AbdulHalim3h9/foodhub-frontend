import React from "react";

// ── Status config ──────────────────────────────────────────────────────────
const STATUS_CONFIG = {
  PENDING:   { label: "Pending",   dot: "#f59e0b", bg: "#fffbeb", text: "#92400e" },
  CONFIRMED: { label: "Confirmed", dot: "#3b82f6", bg: "#eff6ff", text: "#1e40af" },
  PREPARING: { label: "Preparing", dot: "#f97316", bg: "#fff7ed", text: "#9a3412" },
  READY:     { label: "Ready",     dot: "#22c55e", bg: "#f0fdf4", text: "#14532d" },
  COMPLETED: { label: "Completed", dot: "#6b7280", bg: "#f9fafb", text: "#374151" },
  DELIVERED: { label: "Delivered", dot: "#10b981", bg: "#ecfdf5", text: "#065f46" },
  CANCELLED: { label: "Cancelled", dot: "#ef4444", bg: "#fef2f2", text: "#991b1b" },
};

// ── Stars ──────────────────────────────────────────────────────────────────
function Stars({ rating }) {
  return (
    <span style={{ letterSpacing: 1, fontSize: 14 }}>
      {[1, 2, 3, 4, 5].map((s) => (
        <span key={s} style={{ color: s <= rating ? "#f59e0b" : "#d1d5db" }}>★</span>
      ))}
    </span>
  );
}

// ── OrderCard ──────────────────────────────────────────────────────────────
function OrderCard({ order, onViewDetails, onReview, orderReviews }) {
  const cfg = STATUS_CONFIG[order.status] ?? STATUS_CONFIG.COMPLETED;
  const reviews = orderReviews[order.mealId ?? ""] ?? [];
  const hasReview = reviews.length > 0;
  const canReview = order.status === "DELIVERED";

  return (
    <div style={styles.card}>
      {/* Header */}
      <div style={styles.cardHeader}>
        <div>
          <p style={styles.orderNumber}>Order #{order.orderNumber}</p>
          <p style={styles.dateLine}>
            Placed on {new Date(order.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
          </p>
        </div>
        <span style={{ ...styles.badge, background: cfg.bg, color: cfg.text }}>
          <span style={{ ...styles.dot, background: cfg.dot }} />
          {cfg.label}
        </span>
      </div>

      {/* Divider */}
      <div style={styles.divider} />

      {/* Item row */}
      <div style={styles.itemRow}>
        <div style={styles.itemLeft}>
          <div style={styles.qtyBadge}>×{order.quantity}</div>
          <div>
            <p style={styles.mealName}>{order.meal?.name ?? "Meal"}</p>
            <p style={styles.unitPrice}>${Number(order.pricePerItem).toFixed(2)} each</p>
          </div>
        </div>
        <p style={styles.total}>${Number(order.totalAmount).toFixed(2)}</p>
      </div>

      {/* Review block */}
      {canReview && hasReview && (
        <div style={styles.reviewBox}>
          {reviews.map((rev) => (
            <div key={rev.id}>
              <div style={styles.reviewMeta}>
                <Stars rating={rev.rating} />
                <span style={styles.reviewDate}>
                  {new Date(rev.createdAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                </span>
                <button style={styles.deleteBtn} onClick={() => onReview(order)}>
                  Delete
                </button>
              </div>
              {rev.comment && <p style={styles.reviewComment}>{rev.comment}</p>}
            </div>
          ))}
        </div>
      )}

      {/* Footer actions */}
      <div style={styles.footer}>
        <button style={styles.detailsBtn} onClick={() => onViewDetails(order)}>
          View Details
        </button>
        {canReview && (
          <button style={styles.reviewBtn} onClick={() => onReview(order)}>
            {hasReview ? "Delete Review" : "Leave a Review"}
          </button>
        )}
      </div>
    </div>
  );
}

// ── Styles ─────────────────────────────────────────────────────────────────
const styles = {
  card: {
    background: "#fff",
    border: "1px solid #e5e7eb",
    borderRadius: 12,
    padding: "20px 24px",
    fontFamily: "'DM Sans', 'Helvetica Neue', sans-serif",
    boxShadow: "0 1px 4px rgba(0,0,0,.06)",
    transition: "box-shadow .2s",
  },
  cardHeader: {
    display: "flex",
    justifyContent: "space-between",
    alignItems: "flex-start",
  },
  orderNumber: { margin: 0, fontWeight: 600, fontSize: 15, color: "#111827" },
  dateLine: { margin: "3px 0 0", fontSize: 13, color: "#9ca3af" },
  badge: {
    display: "inline-flex",
    alignItems: "center",
    gap: 6,
    padding: "4px 10px",
    borderRadius: 20,
    fontSize: 12,
    fontWeight: 600,
    letterSpacing: ".3px",
    whiteSpace: "nowrap",
  },
  dot: { width: 6, height: 6, borderRadius: "50%", flexShrink: 0 },
  divider: { height: 1, background: "#f3f4f6", margin: "16px 0" },
  itemRow: {
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
  },
  itemLeft: { display: "flex", alignItems: "center", gap: 12 },
  qtyBadge: {
    background: "#f3f4f6",
    color: "#374151",
    borderRadius: 6,
    padding: "3px 8px",
    fontSize: 13,
    fontWeight: 600,
    flexShrink: 0,
  },
  mealName: { margin: 0, fontSize: 14, fontWeight: 600, color: "#1f2937" },
  unitPrice: { margin: "2px 0 0", fontSize: 13, color: "#9ca3af" },
  total: { margin: 0, fontSize: 15, fontWeight: 700, color: "#111827" },
  reviewBox: {
    marginTop: 14,
    background: "#f9fafb",
    border: "1px solid #e5e7eb",
    borderRadius: 8,
    padding: "12px 14px",
  },
  reviewMeta: {
    display: "flex",
    alignItems: "center",
    gap: 10,
    marginBottom: 6,
  },
  reviewDate: { fontSize: 12, color: "#9ca3af", marginLeft: "auto" },
  reviewComment: { margin: 0, fontSize: 13, color: "#374151", lineHeight: 1.5 },
  deleteBtn: {
    background: "none",
    border: "1px solid #e5e7eb",
    borderRadius: 6,
    padding: "2px 8px",
    fontSize: 12,
    color: "#6b7280",
    cursor: "pointer",
  },
  footer: {
    display: "flex",
    gap: 8,
    marginTop: 16,
  },
  detailsBtn: {
    flex: 1,
    background: "#fff",
    border: "1px solid #e5e7eb",
    borderRadius: 8,
    padding: "8px 0",
    fontSize: 13,
    fontWeight: 500,
    color: "#374151",
    cursor: "pointer",
  },
  reviewBtn: {
    background: "#fff7ed",
    border: "1px solid #fed7aa",
    borderRadius: 8,
    padding: "8px 16px",
    fontSize: 13,
    fontWeight: 500,
    color: "#c2410c",
    cursor: "pointer",
    whiteSpace: "nowrap",
  },
};

export default OrderCard;